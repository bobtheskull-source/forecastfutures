{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://health-data-ready/schemas/forecast_market_data.schema.json",
  "title": "ForecastMarketDataRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "market_id",
    "event_id",
    "timestamp",
    "implied_prob",
    "volume",
    "spread",
    "depth",
    "source",
    "freshness_seconds"
  ],
  "properties": {
    "market_id": {"type": "string", "minLength": 1},
    "event_id": {"type": "string", "minLength": 1},
    "timestamp": {"type": "string", "format": "date-time"},
    "implied_prob": {"type": "number", "minimum": 0, "maximum": 1},
    "volume": {"type": "number", "minimum": 0},
    "spread": {"type": "number", "minimum": 0},
    "depth": {"type": "number", "minimum": 0},
    "source": {"type": "string", "minLength": 1},
    "freshness_seconds": {"type": "integer", "minimum": 0}
  }
}
